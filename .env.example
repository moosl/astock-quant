# ============================================================
# A股 量化预测系统 —— 环境变量配置示例
# ============================================================
# 用法：复制本文件为 .env，填入你自己的真实值：
#     cp .env.example .env
#
# .env 已被 .gitignore 排除，永远不会进 git，可以放心填真实 key。
# 千万不要把真实 key 写进本文件（.env.example 会进 git 公开）。
# ============================================================

# --- LLM 情绪因子开关 ---
# 是否启用 LLM 情绪因子（让 AI 读新闻、给每只股票打情绪分）。
#   0 = 关闭（默认，只用量价因子，不需要任何 API key）
#   1 = 开启（需要配下面任一供应商的 API key）
ENABLE_LLM_FACTOR=0

# --- LLM 供应商选择 ---
# 开启 LLM 因子时用哪一家：anthropic（Claude）或 deepseek
LLM_PROVIDER=deepseek

# 指定具体模型（留空则用供应商默认值）
# LLM_MODEL=deepseek-chat

# --- DeepSeek 配置（LLM_PROVIDER=deepseek 时用）---
DEEPSEEK_API_KEY=your-deepseek-key-here
# 只有用中转站 / 自定义 endpoint 才填；官方直连请留空
# DEEPSEEK_BASE_URL=

# --- Anthropic 配置（LLM_PROVIDER=anthropic 时用）---
ANTHROPIC_API_KEY=your-anthropic-key-here
# 只有用中转站 / 自定义 endpoint 才填；官方直连请留空
# ANTHROPIC_BASE_URL=
